# Supabase — copie para .env.local e preencha com os valores do seu projeto.
# Project Settings → API no dashboard do Supabase.
#
# Sem estas variáveis o app roda em modo local (localStorage) e o login fica
# desativado.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Nova publishable key (recomendada): começa com sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Alternativa legada (JWT): use uma OU outra.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
